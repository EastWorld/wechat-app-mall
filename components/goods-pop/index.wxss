.sku-container {
  box-sizing: border-box;
  width: 100vw;
  padding: 32rpx 32rpx 0 32rpx;
}

/* ========== SKU 弹窗价格组件 ========== */

/* 价格整体容器 */
.sku-price-block {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 4rpx 0;
}

/* 免费徽章 */
.sku-price-free-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6B6B 0%, #E4393C 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: bold;
  padding: 4rpx 22rpx;
  border-radius: 22rpx;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 14rpx rgba(228, 57, 60, 0.35);
}

/* 金额区域 */
.sku-price-money-wrap {
  display: inline-flex;
  align-items: baseline;
}

.sku-price-symbol {
  font-size: 28rpx;
  font-weight: bold;
  color: #E4393C;
  margin-right: 2rpx;
}

.sku-price-main {
  font-size: 52rpx;
  font-weight: bold;
  color: #E4393C;
  line-height: 1;
}

/* 划线原价 */
.sku-price-del {
  font-size: 26rpx;
  color: #bbb;
  text-decoration: line-through;
  margin-left: 12rpx;
  align-self: flex-end;
  padding-bottom: 6rpx;
}

/* 积分块 */
.sku-price-score-wrap {
  display: inline-flex;
  align-items: baseline;
  background: linear-gradient(135deg, #FFF8EC 0%, #FFF3DC 100%);
  border: 2rpx solid #F0B840;
  border-radius: 10rpx;
  padding: 6rpx 16rpx;
}

.sku-price-score-num {
  font-size: 46rpx;
  font-weight: bold;
  line-height: 1;
  background: linear-gradient(135deg, #E8971A 0%, #C87800 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.sku-price-score-unit {
  font-size: 24rpx;
  font-weight: bold;
  color: #C87800;
  margin-left: 4rpx;
  align-self: flex-end;
  padding-bottom: 4rpx;
}

/* 金额 + 积分 组合行 */
.sku-price-combo-wrap {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.sku-price-plus {
  font-size: 28rpx;
  color: #aaa;
  font-weight: bold;
  align-self: center;
}

/* ========== SKU 弹窗价格组件结束 ========== */

.sku-container .sku {
  border-bottom: 1rpx solid #eee;
  padding-bottom: 24rpx;
  margin-bottom: 16rpx;
}
.sku-container .sku .t {
  color: #333;
}
.sku-container .sku .items {
  display: flex;
  flex-wrap: wrap;
}
.sku-container .sku .items text {
  padding: 8rpx 16rpx;
  border: 1rpx solid #eee;
  color: #666;
  margin: 24rpx 24rpx 0 0;
  font-size: 26rpx;
  border-radius: 8rpx;
}
.sku-container .sku .items text.active {
  border: 1rpx solid #e64340;
  color: #e64340;
}
.sku-container .num {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.sku-container .num .t {
  color: #333;
}
.btn {
  padding: 32rpx;
}